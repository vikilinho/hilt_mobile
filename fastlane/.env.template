# ─────────────────────────────────────────────────────────────────────────────
# Hilt King – Fastlane Environment Variables Template
#
# USAGE:
#   cp fastlane/.env.template fastlane/.env
#   Fill in the values below, then run:
#     bundle exec fastlane android deploy_play_store
#     bundle exec fastlane ios    deploy_testflight
#
# ⚠️  NEVER commit fastlane/.env to version control.
#     It is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Android / Play Store ──────────────────────────────────────────────────────
# Path to your Google Play Service Account JSON key.
# Generate at: Play Console → Setup → API access → Service accounts
PLAY_STORE_JSON_KEY_PATH=/path/to/play-store-service-account.json

# ── iOS / App Store Connect ───────────────────────────────────────────────────
# Path to your App Store Connect API Key (.p8 file from Certificates page)
APP_STORE_CONNECT_API_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# App Store Connect API Key details (from the API key you created)
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your Apple ID email (used for match + upload)
APPLE_ID=your@email.com

# App Store Connect team ID (numeric, shown in your account settings)
ITC_TEAM_ID=123456789

# Apple Developer Program team ID (10-char alphanumeric)
APPLE_TEAM_ID=XXXXXXXXXX

# ── iOS match (code-signing) ──────────────────────────────────────────────────
# Private git repo that stores encrypted certificates & provisioning profiles.
# Create an empty private repo first, then set the URL here.
MATCH_GIT_URL=https://github.com/your-org/hiltking-match-certs.git

# Password used to encrypt/decrypt the match repo contents
MATCH_PASSWORD=your-super-secret-match-passphrase

# Keychain to use on CI (leave as 'login' for local development)
MATCH_KEYCHAIN_NAME=login
MATCH_KEYCHAIN_PASSWORD=
